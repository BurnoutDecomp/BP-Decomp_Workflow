# Coordination config for the BP work server.
#
# Setup: copy this file to `.env` and paste the worker id the maintainer gave you.
# `work` loads `.env` from the repo root automatically. A real shell environment
# variable always overrides what is set here.
#
#   cp .env.example .env      # then set WORK_AGENT to your issued id
#
# Never commit `.env` (it is git-ignored); only this example is tracked.

# Coordination server URL. Leave unset/commented to work locally (the default — ledger
# + git only, like a solo workflow).
WORK_SERVER=https://decomp.adriwin.fr/

# Your WORKER ID — a unique token the maintainer mints for you (`work worker-add <name>`)
# and gives you privately. The server links it to your username and records that username
# as the owner of your claims; the id itself is never stored or shown. Required to claim
# or submit on the server. (Offline, any label works — it is just the local owner name.)
WORK_AGENT=paste-your-issued-worker-id-here

# How long a claim lease lasts before the server returns abandoned work to `todo`.
WORK_LEASE_SECONDS=7200

